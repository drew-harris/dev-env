#!/usr/bin/env bash
#MISE description="Pick and run a mise task with fzf"
#MISE dir="{{cwd}}"
#MISE quiet=true

# Helper: check if a block's last non-empty line is 'exit'
is_quick_exit() {
    local content="$1"
    local last_line
    last_line=$(echo "$content" | awk '/^[[:space:]]*$/ {next} {last=$0} END {print last}')
    [[ "$last_line" == "exit" ]]
}

# Helper: wait for Enter after task completes (unless quick_exit)
wait_after() {
    echo ""
    read -rp "Press Enter to close"
}

# --- Zed cursor mode ---
# If the active Zed file is a pad.nu, find the block at the cursor.
# Named blocks (#@ Name) are run as mise tasks; anonymous blocks are
# assembled with frontmatter into a temp file and run directly with nu.
if [[ "$(basename "${ZED_FILENAME:-}" 2>/dev/null)" == "pad.nu" && -n "$ZED_ROW" ]]; then
    pad_file="$ZED_FILENAME"

    # Find the #@ block name at or above ZED_ROW (within blank-line boundaries)
    block_name=$(awk -v row="$ZED_ROW" '
        /^#@ / {
            name = substr($0, 4)
        }
        /^[[:space:]]*$/ {
            name = ""
        }
        NR == row {
            if (name != "") print name
            exit
        }
    ' "$pad_file")

    if [[ -n "$block_name" ]]; then
        # Named block — run split to ensure tasks are up to date, then run via mise
        mise run split 2>/dev/null

        # Convert block name to kebab-case (must match split's to-kebab-case)
        task_name=$(echo "$block_name" | tr '[:upper:]' '[:lower:]' | sed -E 's/[[:space:]]+/-/g; s/[^a-z0-9-]//g')

        mise run "$task_name"

        # Check source file for exit sentinel
        task_file=$(mise tasks --json | jq -r --arg name "$task_name" '.[] | select(.name == $name) | .file // ""')
        if [[ -n "$task_file" && -f "$task_file" ]]; then
            is_quick_exit "$(cat "$task_file")" || wait_after
        else
            wait_after
        fi
        exit 0
    fi

    # Anonymous block — extract content and run directly with nu
    block_content=$(awk -v row="$ZED_ROW" '
        BEGIN { buf="" }
        /^[[:space:]]*$/ {
            if (NR < row) {
                buf = ""
            } else {
                exit
            }
            next
        }
        /^#@ / { next }
        { buf = buf $0 "\n" }
        END { printf "%s", buf }
    ' "$pad_file")

    if [[ -z "$block_content" ]]; then
        echo "No block found at row $ZED_ROW"
        exit 1
    fi

    # Extract frontmatter (everything before the first ### line)
    frontmatter=$(awk '/^###$/ {exit} {print}' "$pad_file" | sed '/^$/d')

    tmp_dir=$(mktemp -d)
    trap 'rm -rf "$tmp_dir"' EXIT

    {
        printf "%s\n\n" "$frontmatter"
        printf "%s\n" "$block_content"
    } > "$tmp_dir/script.nu"

    mise x -- nu "$tmp_dir/script.nu"
    is_quick_exit "$block_content" || wait_after
    exit 0
fi

# --- Normal fzf mode ---
# Run split first to regenerate tasks from pad.nu
mise run split 2>/dev/null

# Cache task metadata so both the list and preview can use it
tasks_json=$(mise tasks --json)

# Build fzf input: name<tab>file<tab>description
# Pad the name column for alignment, use tab as fzf field delimiter
max_name_len=$(echo "$tasks_json" | jq -r '[ .[] | .name | length ] | max')
selected=$(
  echo "$tasks_json" \
    | jq -r --argjson w "$max_name_len" '.[] | "\(.name | . + " " * ($w - length))\t\(.file // "")\t\(.description // "")"' \
    | fzf --reverse --prompt 'task: ' --bind change:top \
          --delimiter "\t" --with-nth '1,3' \
          --preview 'file={2}; if [ -n "$file" ] && [ -f "$file" ]; then
              echo -e "\033[1;34mTask:\033[0m {1}"
              echo -e "\033[1;34mFile:\033[0m $file"
              echo ""
              bat --color=always --style=numbers --language=bash "$file" 2>/dev/null || cat "$file"
          else
              echo -e "\033[1;34mTask:\033[0m {1}"
              echo ""
              echo "(inline task — no file to preview)"
          fi' \
          --preview-window 'right:60%'
) || exit 0

[[ -z "$selected" ]] && exit 0

task_name=$(echo "$selected" | cut -f1 | awk '{print $1}')
task_file=$(echo "$tasks_json" | jq -r --arg name "$task_name" '.[] | select(.name == $name) | .file // ""')

# Run the task
mise run "$task_name"

# Check the task's source file for the exit sentinel
if [[ -n "$task_file" && -f "$task_file" ]]; then
    file_content=$(cat "$task_file")
    is_quick_exit "$file_content" || wait_after
else
    wait_after
fi
